// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String   @unique
  password  String
  name      String
  isAdmin   Boolean  @default(false)
  coins     BigInt   @default(0)
  taps      BigInt   @default(0)
  energy    Int      @default(100)
  maxEnergy Int      @default(100)
  rank      String   @default("Beginner")
  
  deposits  Deposit[]
  withdraws Withdraw[]
  taps_log  TapLog[]
  converts  Convert[]
  claims    Claim[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TapLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    BigInt
  createdAt DateTime @default(now())
}

model Convert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromCoins BigInt
  toCoins   BigInt
  rate      Float
  createdAt DateTime @default(now())
}

model Deposit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    BigInt
  status    String   @default("pending") // pending, completed, rejected
  method    String   @default("bank")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Withdraw {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    BigInt
  status    String   @default("pending") // pending, completed, rejected
  bankName  String?
  bankAccNumber String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Claim {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    BigInt
  createdAt DateTime @default(now())
}